@model BlogWebApp.Models.BlogPost?
@inject BlogWebApp.Services.IMarkdownRenderer Markdown
@{
    ViewData["Title"] = "Now";
}

<h1>Now</h1>

@if (Model == null)
{
    <p>Nothing here yet.</p>
}
else
{
    <article>
        <div>@Markdown.Render(Model.Content, Model.Format)</div>
        @if (Model.DateUpdated.HasValue)
        {
            <p class="text-muted small mt-3">Last updated @Model.DateUpdated.Value.ToString("MMMM d, yyyy")</p>
        }
    </article>
}
