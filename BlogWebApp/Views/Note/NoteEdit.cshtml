@model BlogWebApp.ViewModels.NoteEditViewModel
@{
    ViewData["Title"] = "Edit note";
}

<h2>Note</h2>

@if (ViewBag.Success == true)
{
    <div class="alert alert-success">Saved.</div>
}

<form method="post" class="col-md-10">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="LinkUrl" class="form-label"></label>
        <input asp-for="LinkUrl" class="form-control" type="url" />
    </div>

    <div class="mb-3">
        <label asp-for="Content" class="form-label"></label>
        <textarea asp-for="Content" class="form-control" rows="10"></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>
