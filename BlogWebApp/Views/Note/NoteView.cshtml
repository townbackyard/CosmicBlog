@model BlogWebApp.ViewModels.NoteViewViewModel
@inject BlogWebApp.Services.IMarkdownRenderer Markdown
@section Head {
    @await Html.PartialAsync("_OgTags", Model)
    @await Html.PartialAsync("_JsonLd", Model)
}
@{
    ViewData["Title"] = string.IsNullOrEmpty(Model.Title) ? "Note" : Model.Title;
}

<article>
    @if (!string.IsNullOrEmpty(Model.Title))
    {
        <h1>@Model.Title</h1>
    }
    <div class="text-muted mb-3">@Model.DateCreated.ToString("MMMM d, yyyy")</div>
    @if (Model.Tags?.Any() == true)
    {
        <p class="text-muted small">
            Tagged:
            @foreach (var tag in Model.Tags)
            {
                <a asp-controller="Tag" asp-action="Tag" asp-route-tag="@tag">@tag</a>
                <text> </text>
            }
        </p>
    }
    <div>@Markdown.Render(Model.Content, Model.Format)</div>
    @if (!string.IsNullOrEmpty(Model.LinkUrl))
    {
        <p class="mt-3"><a href="@Model.LinkUrl">@Model.LinkUrl</a></p>
    }
</article>
