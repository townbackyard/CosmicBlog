@model List<BlogWebApp.Models.BlogPost>
@inject Microsoft.Extensions.Options.IOptions<BlogWebApp.AppSettings> AppSettings
@inject BlogWebApp.Services.IMarkdownRenderer Markdown
@{
    ViewData["Title"] = "Home";
}

<header class="mb-4">
    <h1>@AppSettings.Value.BlogName</h1>
    <p class="lead">@AppSettings.Value.SiteDescription</p>
</header>

<section>
    <h2 class="visually-hidden">Activity</h2>
    @if (!Model.Any())
    {
        <p>Nothing here yet.</p>
    }
    else
    {
        <ul class="list-unstyled">
            @foreach (var item in Model)
            {
                var slugOrId = string.IsNullOrEmpty(item.Slug) ? item.PostId : item.Slug;
                var itemUrl = item.Type == "post"
                    ? Url.Action("PostView", "BlogPost", new { slug = item.Slug })
                    : Url.Action("NoteView", "Note", new { slugOrId = slugOrId });

                <li class="mb-4 pb-3 border-bottom">
                    <div class="small text-uppercase text-muted mb-1">
                        @item.Type · @item.DateCreated.ToString("MMM d, yyyy")
                    </div>
                    @if (!string.IsNullOrEmpty(item.Title))
                    {
                        <h3 class="mb-1"><a href="@itemUrl">@item.Title</a></h3>
                    }
                    @if (item.Type == "note")
                    {
                        <div>@Markdown.Render(item.Content, item.Format)</div>
                        @if (!string.IsNullOrEmpty(item.LinkUrl))
                        {
                            <div class="small"><a href="@item.LinkUrl">@item.LinkUrl</a></div>
                        }
                    }
                    else
                    {
                        <p class="mb-0"><a href="@itemUrl">Read post →</a></p>
                    }
                </li>
            }
        </ul>
    }
</section>
