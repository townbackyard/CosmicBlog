@model List<BlogWebApp.Models.BlogPost>
@{
    ViewData["Title"] = "Posts";
}

<h1>Posts</h1>

@if (!Model.Any())
{
    <p>No posts yet.</p>
}
else
{
    <ul class="list-unstyled">
        @foreach (var post in Model)
        {
            <li class="mb-3">
                <h3 class="mb-1">
                    <a asp-controller="BlogPost" asp-action="PostView" asp-route-slug="@post.Slug">@post.Title</a>
                </h3>
                <small class="text-muted">@post.DateCreated.ToString("MMM d, yyyy")</small>
            </li>
        }
    </ul>
}
