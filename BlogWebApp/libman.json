{
  "version": "1.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "provider": "cdnjs",
      "library": "twitter-bootstrap@5.3.3",
      "destination": "wwwroot/lib/bootstrap/"
    },
    {
      "provider": "cdnjs",
      "library": "tinymce@7.6.1",
      "destination": "wwwroot/lib/tinymce/"
    },
    {
      "provider": "unpkg",
      "library": "easymde@2.18.0",
      "destination": "wwwroot/lib/easymde/",
      "files": [ "dist/easymde.min.js", "dist/easymde.min.css" ]
    }
  ]
}
